# ── Server ────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=http://localhost:5500

# ── Anthropic (AI letter body generation) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email (Gmail App Password or SMTP relay) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=documents@kadabaconstruction.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Kadaba Construction Ltd <documents@kadabaconstruction.com>

# ── Storage ───────────────────────────────────────────────────
GENERATED_DIR=./generated

# ── Chromium path for Puppeteer (HTML→PDF) ───────────────────
# Leave blank to auto-detect. On Ubuntu: /usr/bin/chromium-browser
# On macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROMIUM_PATH=

# ── HTML2PDF (HTML→PDF) ───────────────────
HTML2PDF_API_KEY=